# wall_front.obj
# Pared frontal — con PUERTA (abertura)
# Dimensiones totales: 8m ancho (X: -4 a +4) × 3m alto (Y: 0 a 3)
# Puerta centrada en X=0: ancho=1m (X: -0.5 a +0.5), alto=2.1m (Y: 0 a 2.1)
# Plano XY, normal apuntando hacia +Z
#
# La malla se divide en 5 rectángulos para rodear el hueco:
#
#  ┌─────────┬────┬─────────┐  Y=3.0
#  │         │    │         │
#  │  PANEL  │TOP │  PANEL  │
#  │  IZQ    │    │  DER    │  Y=2.1
#  │         ├────┤         │
#  │         │    │         │
#  │         │    │         │  Y=0.0
#  └─────────┴────┴─────────┘
#  X=-4    X=-0.5 X=0.5    X=+4
#
#  Panel izquierdo  : X=-4  a X=-0.5, Y=0 a Y=3   → 2 triángulos
#  Panel derecho    : X=+0.5 a X=+4,  Y=0 a Y=3   → 2 triángulos
#  Panel superior   : X=-0.5 a X=+0.5,Y=2.1 a Y=3 → 2 triángulos
#  (el hueco Y=0 a Y=2.1, X=-0.5 a X=0.5 queda vacío = la puerta)

# ── Vértices ────────────────────────────────────────────────────────────────

# Panel izquierdo (X: -4 → -0.5, Y: 0 → 3)
v -4.0 0.0 0.0   # 1
v -0.5 0.0 0.0   # 2
v -0.5 3.0 0.0   # 3
v -4.0 3.0 0.0   # 4

# Panel derecho (X: 0.5 → 4, Y: 0 → 3)
v 0.5 0.0 0.0   # 5
v 4.0 0.0 0.0   # 6
v 4.0 3.0 0.0   # 7
v 0.5 3.0 0.0   # 8

# Panel superior sobre la puerta (X: -0.5 → 0.5, Y: 2.1 → 3)
v -0.5 2.1 0.0   # 9
v 0.5 2.1 0.0   # 10
v 0.5 3.0 0.0   # 11  (= misma posición que v8 pero vértice propio)
v -0.5 3.0 0.0   # 12  (= misma posición que v3 pero vértice propio)

# ── Caras ────────────────────────────────────────────────────────────────────

# Panel izquierdo
f 1 2 3
f 1 3 4

# Panel derecho
f 5 6 7
f 5 7 8

# Panel superior (dintel sobre la puerta)
f 9 10 11
f 9 11 12

##al reves
f 3 2 1
f 4 3 1

f 7 6 5
f 8 7 5

f 11 10 9
f 12 11 9


