# Cubo Unitario Centrado
# Dimensiones: 1x1x1 (de -0.5 a 0.5 en los tres ejes)

# Vértices (x, y, z)
v -0.5 -0.5 0.5
v 0.5 -0.5 0.5
v 0.5 0.5 0.5
v -0.5 0.5 0.5
v -0.5 -0.5 -0.5
v 0.5 -0.5 -0.5
v 0.5 0.5 -0.5
v -0.5 0.5 -0.5

# Caras (f) - Definidas para verse de ambos lados
# Lado exterior (Normales hacia afuera)
f 1 2 3 4
f 8 7 6 5
f 4 3 7 8
f 5 1 4 8
f 2 6 7 3
f 1 5 6 2

# Lado interior (Invertidas por si entras al cubo)
f 4 3 2 1
f 5 6 7 8
f 8 7 3 4
f 8 4 1 5
f 3 7 6 2
f 2 6 5 1