# wall_right.obj
# Pared derecha — con VENTANA (abertura)
# Dimensiones totales: 6m de profundidad (Z: 0 a 6) × 3m alto (Y: 0 a 3)
# Ventana centrada en Z=3: ancho=1.5m (Z: 2.25 a 3.75), Y: 0.9m a 2.1m
# Plano ZY, normal apuntando hacia -X (hacia el interior)
#
# La malla se divide en 6 rectángulos para rodear el hueco:
#
#  ┌──────────────┬───────────┬──────────────┐  Y=3.0
#  │              │  SUPERIOR │              │
#  │              ├───────────┤              │  Y=2.1
#  │  PANEL IZQ   │  (HUECO)  │  PANEL DER   │
#  │  (completo)  ├───────────┤  (completo)  │  Y=0.9
#  │              │  INFERIOR │              │
#  └──────────────┴───────────┴──────────────┘  Y=0.0
#  Z=0          Z=2.25      Z=3.75            Z=6
#
# 6 paneles × 2 triángulos = 12 triángulos

# ── Vértices ────────────────────────────────────────────────────────────────

# Panel izquierdo completo (Z: 0 → 2.25, Y: 0 → 3)
v 0.0 0.0 0.0    # 1
v 0.0 0.0 2.25   # 2
v 0.0 3.0 2.25   # 3
v 0.0 3.0 0.0    # 4

# Panel derecho completo (Z: 3.75 → 6, Y: 0 → 3)
v 0.0 0.0 3.75   # 5
v 0.0 0.0 6.0    # 6
v 0.0 3.0 6.0    # 7
v 0.0 3.0 3.75   # 8

# Panel inferior bajo la ventana (Z: 2.25 → 3.75, Y: 0 → 0.9)
v 0.0 0.0 2.25   # 9
v 0.0 0.0 3.75   # 10
v 0.0 0.9 3.75   # 11
v 0.0 0.9 2.25   # 12

# Panel superior sobre la ventana (Z: 2.25 → 3.75, Y: 2.1 → 3)
v 0.0 2.1 2.25   # 13
v 0.0 2.1 3.75   # 14
v 0.0 3.0 3.75   # 15
v 0.0 3.0 2.25   # 16

# ── Caras ────────────────────────────────────────────────────────────────────

# Panel izquierdo
f 1 2 3
f 1 3 4

# Panel derecho
f 5 6 7
f 5 7 8

# Panel inferior (antepecho de ventana)
f 9 10 11
f 9 11 12

# Panel superior (dintel de ventana)
f 13 14 15
f 13 15 16


##al reves
f 3 2 1
f 4 3 1

f 7 6 5
f 8 7 5

f 11 10 9
f 12 11 9

f 15 14 13
f 16 15 13
